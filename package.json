{
  "name": "tanglishscript",
  "version": "1.0.0",
  "description": "TanglishScript — Telugu-English Web Programming Language",
  "main": "tanglish-cli.js",
  "bin": {
    "tanglish": "./tanglish-cli.js"
  },
  "scripts": {
    "build": "node tanglish-cli.js build examples/app.tang",
    "build:complete": "node tanglish-cli.js build examples/complete.tang",
    "build:style": "node tanglish-cli.js build examples/style.tang",
    "run:app": "node tanglish-cli.js run examples/app.tang",
    "run:complete": "node tanglish-cli.js run examples/complete.tang",
    "check": "node tanglish-cli.js check examples/app.tang",
    "ide": "node -e \"const h=require('http'),f=require('fs'),p=require('path');const s=h.createServer((q,r)=>{let fp=p.join(__dirname,'ide',q.url==='/'?'index.html':q.url);if(fs.existsSync(fp)){r.writeHead(200);r.end(f.readFileSync(fp))}else{r.writeHead(404);r.end('Not found')}});s.listen(4200,()=>console.log('IDE running at http://localhost:4200'))\"",
    "learn": "node -e \"const h=require('http'),f=require('fs'),p=require('path');const s=h.createServer((q,r)=>{let fp=p.join(__dirname,'learn',q.url==='/'?'index.html':q.url);if(fs.existsSync(fp)){r.writeHead(200);r.end(f.readFileSync(fp))}else{r.writeHead(404);r.end('Not found')}});s.listen(4300,()=>console.log('Learn portal running at http://localhost:4300'))\"",
    "dev": "npm run ide & npm run learn"
  },
  "keywords": [
    "tanglishscript",
    "telugu",
    "programming-language",
    "compiler",
    "transpiler",
    "web"
  ],
  "author": "TanglishScript Team",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {},
}
